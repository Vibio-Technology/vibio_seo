{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.vibio.local/seo_inspect.report/1.3/schema.json",
  "title": "Vibio SEO 产物检查报告",
  "description": "runtime/seo_inspect.py 输出的有界、证据导向 SEO 检查报告契约。",
  "type": "object",
  "required": [
    "schema_version",
    "analysis_kind",
    "tool",
    "version",
    "generated_at",
    "scope",
    "summary",
    "limitations",
    "findings",
    "pages",
    "rendering_comparison"
  ],
  "properties": {
    "schema_version": {"const": "1.3"},
    "analysis_kind": {"const": "bounded_seo_artifact_inspection"},
    "tool": {"const": "vibio-seo-inspect"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+].*)?$"},
    "generated_at": {"type": "string", "minLength": 1},
    "scope": {"$ref": "#/$defs/scope"},
    "summary": {"$ref": "#/$defs/summary"},
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "findings": {
      "type": "array",
      "items": {"$ref": "#/$defs/finding"}
    },
    "pages": {
      "type": "array",
      "items": {"$ref": "#/$defs/page"}
    },
    "rendering_comparison": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/$defs/renderingComparison"}
      ]
    }
  },
  "additionalProperties": true,
  "allOf": [
    {
      "if": {
        "properties": {
          "scope": {
            "properties": {"source_comparison_provided": {"const": true}}
          }
        }
      },
      "then": {"properties": {"rendering_comparison": {"type": "object"}}},
      "else": {"properties": {"rendering_comparison": {"type": "null"}}}
    }
  ],
  "$defs": {
    "nonNegativeInteger": {"type": "integer", "minimum": 0},
    "nullableNonNegativeInteger": {"type": ["integer", "null"], "minimum": 0},
    "stringArray": {"type": "array", "items": {"type": "string"}},
    "fileReference": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*\\\\)(?![A-Za-z][A-Za-z0-9+.-]*:)(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+"
    },
    "artifactSourceReference": {
      "anyOf": [
        {"type": "string", "pattern": "^https?://", "minLength": 8},
        {"$ref": "#/$defs/fileReference"}
      ]
    },
    "scope": {
      "type": "object",
      "required": [
        "mode",
        "evidence_mode",
        "base_url",
        "pages_parsed",
        "known_assets",
        "fetches",
        "sitemap_urls",
        "robots_source",
        "production_asserted",
        "fetch_mode",
        "javascript_rendered",
        "client_side_dom_verified",
        "browser_provenance_verified",
        "browser_provenance",
        "http_response_verified",
        "source_comparison_provided",
        "javascript_runtime_executed_by_tool",
        "sitemap_seeded_crawl"
      ],
      "properties": {
        "mode": {"enum": ["local", "remote"]},
        "evidence_mode": {"enum": ["http_source", "static_build", "browser_dom"]},
        "base_url": {"type": "string", "minLength": 1},
        "pages_parsed": {"$ref": "#/$defs/nonNegativeInteger"},
        "known_assets": {"$ref": "#/$defs/nonNegativeInteger"},
        "fetches": {"$ref": "#/$defs/nonNegativeInteger"},
        "sitemap_urls": {"$ref": "#/$defs/nonNegativeInteger"},
        "robots_source": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "#/$defs/artifactSourceReference"}
          ]
        },
        "production_asserted": {"type": "boolean"},
        "fetch_mode": {"enum": ["raw-http-source", "static-build-files", "browser-exported-dom"]},
        "javascript_rendered": {"type": "boolean"},
        "client_side_dom_verified": {"type": "boolean"},
        "browser_provenance_verified": {"type": "boolean"},
        "browser_provenance": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "#/$defs/browserProvenance"}
          ]
        },
        "http_response_verified": {"type": "boolean"},
        "source_comparison_provided": {"type": "boolean"},
        "javascript_runtime_executed_by_tool": {"const": false},
        "sitemap_seeded_crawl": {"type": "boolean"}
      },
      "additionalProperties": true,
      "allOf": [
        {
          "if": {"properties": {"evidence_mode": {"const": "http_source"}}},
          "then": {
            "properties": {
              "mode": {"const": "remote"},
              "fetch_mode": {"const": "raw-http-source"},
              "javascript_rendered": {"const": false},
              "client_side_dom_verified": {"const": false},
              "browser_provenance_verified": {"const": false},
              "browser_provenance": {"type": "null"},
              "http_response_verified": {"const": true},
              "source_comparison_provided": {"const": false}
            }
          }
        },
        {
          "if": {"properties": {"evidence_mode": {"const": "static_build"}}},
          "then": {
            "properties": {
              "mode": {"const": "local"},
              "fetch_mode": {"const": "static-build-files"},
              "javascript_rendered": {"const": false},
              "client_side_dom_verified": {"const": false},
              "browser_provenance_verified": {"const": false},
              "browser_provenance": {"type": "null"},
              "http_response_verified": {"const": false},
              "source_comparison_provided": {"const": false}
            }
          }
        },
        {
          "if": {"properties": {"evidence_mode": {"const": "browser_dom"}}},
          "then": {
            "properties": {
              "mode": {"const": "local"},
              "fetch_mode": {"const": "browser-exported-dom"},
              "http_response_verified": {"const": false}
            }
          }
        },
        {
          "if": {
            "properties": {"browser_provenance_verified": {"const": true}},
            "required": ["browser_provenance_verified"]
          },
          "then": {
            "properties": {
              "evidence_mode": {"const": "browser_dom"},
              "javascript_rendered": {"const": true},
              "client_side_dom_verified": {"const": true},
              "browser_provenance": {"$ref": "#/$defs/browserProvenance"}
            }
          },
          "else": {
            "properties": {
              "javascript_rendered": {"const": false},
              "client_side_dom_verified": {"const": false},
              "browser_provenance": {"type": "null"}
            }
          }
        }
      ]
    },
    "browserProvenance": {
      "type": "object",
      "required": [
        "source",
        "schema_version",
        "capture_method",
        "browser",
        "captured_at",
        "javascript_enabled",
        "documents_verified",
        "provenance_sha256"
      ],
      "properties": {
        "source": {"$ref": "#/$defs/fileReference"},
        "schema_version": {"const": "1.0"},
        "capture_method": {"type": "string", "minLength": 1},
        "browser": {"type": "string", "minLength": 1},
        "captured_at": {"type": "string", "format": "date-time"},
        "javascript_enabled": {"const": true},
        "documents_verified": {"type": "integer", "minimum": 1},
        "provenance_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "finding_counts",
        "status_counts",
        "noindex_pages",
        "orphan_pages_in_scope",
        "reachable_pages_from_root",
        "max_observed_click_depth"
      ],
      "properties": {
        "finding_counts": {
          "type": "object",
          "required": ["critical", "high", "medium", "low", "info"],
          "properties": {
            "critical": {"$ref": "#/$defs/nonNegativeInteger"},
            "high": {"$ref": "#/$defs/nonNegativeInteger"},
            "medium": {"$ref": "#/$defs/nonNegativeInteger"},
            "low": {"$ref": "#/$defs/nonNegativeInteger"},
            "info": {"$ref": "#/$defs/nonNegativeInteger"}
          },
          "additionalProperties": {"$ref": "#/$defs/nonNegativeInteger"}
        },
        "status_counts": {
          "type": "object",
          "additionalProperties": {"$ref": "#/$defs/nonNegativeInteger"}
        },
        "noindex_pages": {"$ref": "#/$defs/nonNegativeInteger"},
        "orphan_pages_in_scope": {"$ref": "#/$defs/nonNegativeInteger"},
        "reachable_pages_from_root": {"$ref": "#/$defs/nonNegativeInteger"},
        "max_observed_click_depth": {"$ref": "#/$defs/nullableNonNegativeInteger"}
      },
      "additionalProperties": true
    },
    "finding": {
      "type": "object",
      "required": [
        "code",
        "severity",
        "category",
        "observation",
        "urls",
        "evidence",
        "impact_boundary",
        "verification",
        "confidence"
      ],
      "properties": {
        "code": {"type": "string", "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)+$"},
        "severity": {"enum": ["critical", "high", "medium", "low", "info"]},
        "category": {"type": "string", "minLength": 1},
        "observation": {"type": "string", "minLength": 1},
        "urls": {"$ref": "#/$defs/stringArray"},
        "evidence": {"$ref": "#/$defs/stringArray"},
        "impact_boundary": {"type": "string", "minLength": 1},
        "verification": {"type": "string", "minLength": 1},
        "confidence": {"enum": ["high", "medium", "low"]}
      },
      "additionalProperties": true
    },
    "redirect": {
      "type": "object",
      "required": ["url", "status", "location"],
      "properties": {
        "url": {"type": "string", "minLength": 1},
        "status": {"type": "integer", "minimum": 300, "maximum": 399},
        "location": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "hreflang": {
      "type": "object",
      "required": ["lang", "url"],
      "properties": {
        "lang": {"type": "string", "minLength": 1},
        "url": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "linkEdge": {
      "type": "object",
      "required": ["source", "target", "anchor", "rel"],
      "properties": {
        "source": {"type": "string", "minLength": 1},
        "target": {"type": "string", "minLength": 1},
        "anchor": {"type": "string"},
        "rel": {"$ref": "#/$defs/stringArray"}
      },
      "additionalProperties": true
    },
    "image": {
      "type": "object",
      "required": ["src", "alt_present", "alt", "width_present", "height_present"],
      "properties": {
        "src": {"type": "string"},
        "alt_present": {"type": "boolean"},
        "alt": {"type": "string"},
        "width_present": {"type": "boolean"},
        "height_present": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "imageResource": {
      "type": "object",
      "required": ["element", "attribute", "raw", "url"],
      "properties": {
        "element": {"enum": ["img", "source"]},
        "attribute": {
          "enum": [
            "src",
            "data-src",
            "data-lazy-src",
            "data-original",
            "data-flickity-lazyload",
            "data-echo",
            "srcset",
            "data-srcset",
            "data-lazy-srcset",
            "data-original-srcset"
          ]
        },
        "raw": {"type": "string", "minLength": 1},
        "url": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "signalDifference": {
      "type": "object",
      "required": ["source", "rendered", "changed"],
      "properties": {
        "source": {},
        "rendered": {},
        "changed": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "renderingComparisonPage": {
      "type": "object",
      "required": [
        "url",
        "source_source",
        "rendered_source",
        "source_html_sha256",
        "rendered_html_sha256",
        "html_changed",
        "differences"
      ],
      "properties": {
        "url": {"type": "string", "minLength": 1},
        "source_source": {"$ref": "#/$defs/fileReference"},
        "rendered_source": {"$ref": "#/$defs/fileReference"},
        "source_html_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "rendered_html_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "html_changed": {"type": "boolean"},
        "differences": {
          "type": "object",
          "required": [
            "titles",
            "descriptions",
            "canonicals",
            "robots",
            "internal_links",
            "json_ld_types",
            "visible_text_sha256",
            "visible_text_length",
            "h1_count",
            "main_count"
          ],
          "properties": {
            "titles": {"$ref": "#/$defs/signalDifference"},
            "descriptions": {"$ref": "#/$defs/signalDifference"},
            "canonicals": {"$ref": "#/$defs/signalDifference"},
            "robots": {"$ref": "#/$defs/signalDifference"},
            "internal_links": {"$ref": "#/$defs/signalDifference"},
            "json_ld_types": {"$ref": "#/$defs/signalDifference"},
            "visible_text_sha256": {"$ref": "#/$defs/signalDifference"},
            "visible_text_length": {"$ref": "#/$defs/signalDifference"},
            "h1_count": {"$ref": "#/$defs/signalDifference"},
            "main_count": {"$ref": "#/$defs/signalDifference"}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "renderingComparison": {
      "type": "object",
      "required": ["source_input", "matched_pages", "source_only_urls", "rendered_only_urls", "pages"],
      "properties": {
        "source_input": {"$ref": "#/$defs/fileReference"},
        "matched_pages": {"$ref": "#/$defs/nonNegativeInteger"},
        "source_only_urls": {"$ref": "#/$defs/stringArray"},
        "rendered_only_urls": {"$ref": "#/$defs/stringArray"},
        "pages": {"type": "array", "items": {"$ref": "#/$defs/renderingComparisonPage"}}
      },
      "additionalProperties": false
    },
    "page": {
      "type": "object",
      "required": [
        "url",
        "source",
        "evidence_mode",
        "requested_url",
        "status",
        "final_url",
        "content_type",
        "response_headers",
        "document_base_url",
        "html_sha256",
        "visible_text_sha256",
        "visible_text_length",
        "redirect_chain",
        "titles",
        "descriptions",
        "canonicals",
        "robots",
        "hreflang",
        "internal_links",
        "external_links",
        "link_edges",
        "images",
        "image_resources",
        "json_ld_types",
        "json_ld_errors",
        "html_lang",
        "h1_count",
        "main_count",
        "anchor_count",
        "anchors_without_href",
        "non_anchor_link_controls",
        "depth",
        "noindex",
        "inbound_links_in_scope"
      ],
      "properties": {
        "url": {"type": "string", "minLength": 1},
        "source": {"$ref": "#/$defs/artifactSourceReference"},
        "evidence_mode": {"enum": ["http_source", "static_build", "browser_dom"]},
        "requested_url": {"type": "string", "minLength": 1},
        "status": {"type": ["integer", "null"], "minimum": 100, "maximum": 599},
        "final_url": {"type": "string", "minLength": 1},
        "content_type": {"type": "string"},
        "response_headers": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {"type": "string"}
          }
        },
        "document_base_url": {"type": "string", "minLength": 1},
        "html_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "visible_text_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "visible_text_length": {"$ref": "#/$defs/nonNegativeInteger"},
        "redirect_chain": {"type": "array", "items": {"$ref": "#/$defs/redirect"}},
        "titles": {"$ref": "#/$defs/stringArray"},
        "descriptions": {"$ref": "#/$defs/stringArray"},
        "canonicals": {"$ref": "#/$defs/stringArray"},
        "robots": {"$ref": "#/$defs/stringArray"},
        "hreflang": {"type": "array", "items": {"$ref": "#/$defs/hreflang"}},
        "internal_links": {"$ref": "#/$defs/stringArray"},
        "external_links": {"$ref": "#/$defs/stringArray"},
        "link_edges": {"type": "array", "items": {"$ref": "#/$defs/linkEdge"}},
        "images": {"type": "array", "items": {"$ref": "#/$defs/image"}},
        "image_resources": {"type": "array", "items": {"$ref": "#/$defs/imageResource"}},
        "json_ld_types": {"$ref": "#/$defs/stringArray"},
        "json_ld_errors": {"$ref": "#/$defs/stringArray"},
        "html_lang": {"type": "string"},
        "h1_count": {"$ref": "#/$defs/nonNegativeInteger"},
        "main_count": {"$ref": "#/$defs/nonNegativeInteger"},
        "anchor_count": {"$ref": "#/$defs/nonNegativeInteger"},
        "anchors_without_href": {"$ref": "#/$defs/stringArray"},
        "non_anchor_link_controls": {"$ref": "#/$defs/stringArray"},
        "depth": {"$ref": "#/$defs/nullableNonNegativeInteger"},
        "noindex": {"type": "boolean"},
        "inbound_links_in_scope": {"$ref": "#/$defs/nonNegativeInteger"}
      },
      "additionalProperties": true
    }
  }
}
