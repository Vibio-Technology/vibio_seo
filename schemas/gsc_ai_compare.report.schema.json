{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.vibio.local/gsc_ai_compare.report/1.2/schema.json",
  "title": "Vibio GSC 生成式 AI 展示次数窗口比较报告",
  "description": "runtime/gsc_ai_compare.py 输出的严格、仅展示次数的描述性报告契约。",
  "type": "object",
  "required": [
    "schema_version",
    "analysis_kind",
    "generated_at",
    "methodology",
    "limitations",
    "dataset_contract",
    "periods",
    "coverage",
    "sources",
    "data_quality",
    "verdict_eligibility",
    "overall",
    "cohorts"
  ],
  "properties": {
    "schema_version": {"const": "1.2"},
    "analysis_kind": {"const": "descriptive_gsc_generative_ai_window_comparison"},
    "generated_at": {"type": "string", "minLength": 1},
    "methodology": {"$ref": "#/$defs/methodology"},
    "limitations": {"$ref": "#/$defs/limitations"},
    "dataset_contract": {"$ref": "#/$defs/datasetContract"},
    "periods": {
      "type": "object",
      "required": ["baseline", "current"],
      "properties": {
        "baseline": {"$ref": "#/$defs/period"},
        "current": {"$ref": "#/$defs/period"}
      },
      "additionalProperties": false
    },
    "coverage": {"$ref": "#/$defs/coverage"},
    "sources": {
      "type": "object",
      "required": ["baseline", "current"],
      "properties": {
        "baseline": {"$ref": "#/$defs/baselineSource"},
        "current": {"$ref": "#/$defs/currentSource"}
      },
      "additionalProperties": false
    },
    "data_quality": {"$ref": "#/$defs/reportQuality"},
    "verdict_eligibility": {"$ref": "#/$defs/verdictEligibility"},
    "overall": {"$ref": "#/$defs/overall"},
    "cohorts": {
      "type": "object",
      "required": ["page", "country", "device"],
      "properties": {
        "page": {"$ref": "#/$defs/cohort"},
        "country": {"$ref": "#/$defs/cohort"},
        "device": {"$ref": "#/$defs/cohort"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "nullableString": {
      "type": ["string", "null"]
    },
    "nullableOffsetDateTime": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "string",
          "format": "date-time",
          "pattern": "(?:[Zz]|[+-][0-9]{2}:[0-9]{2})$"
        }
      ]
    },
    "nonNegativeNumber": {
      "type": "number",
      "minimum": 0
    },
    "nonNegativeInteger": {
      "type": "integer",
      "minimum": 0
    },
    "fileReference": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*\\\\)(?![A-Za-z][A-Za-z0-9+.-]*:)(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+"
    },
    "dimension": {
      "enum": ["page", "country", "device"]
    },
    "grainField": {
      "enum": ["date", "page", "country", "device"]
    },
    "methodology": {
      "type": "object",
      "required": [
        "metric",
        "causal_inference",
        "aggregation",
        "zero_denominator",
        "warnings",
        "official_sources"
      ],
      "properties": {
        "metric": {"const": "impressions_only"},
        "causal_inference": {"const": false},
        "aggregation": {"type": "string", "minLength": 1},
        "zero_denominator": {"type": "string", "minLength": 1},
        "warnings": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "official_sources": {
          "type": "array",
          "minItems": 3,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^https://"}
        }
      },
      "additionalProperties": false
    },
    "limitations": {
      "type": "object",
      "required": [
        "web_performance_subset",
        "additive_with_web_performance",
        "query_available_or_inferred",
        "clicks_available_or_inferred",
        "ctr_available_or_inferred",
        "citations_available_or_inferred",
        "conversions_available_or_inferred",
        "ranking_or_causality_supported",
        "included_features_documented",
        "search_labs_experiments_included"
      ],
      "properties": {
        "web_performance_subset": {"const": true},
        "additive_with_web_performance": {"const": false},
        "query_available_or_inferred": {"const": false},
        "clicks_available_or_inferred": {"const": false},
        "ctr_available_or_inferred": {"const": false},
        "citations_available_or_inferred": {"const": false},
        "conversions_available_or_inferred": {"const": false},
        "ranking_or_causality_supported": {"const": false},
        "included_features_documented": {
          "type": "array",
          "prefixItems": [
            {"const": "AI Overviews"},
            {"const": "AI Mode"}
          ],
          "items": false,
          "minItems": 2,
          "maxItems": 2
        },
        "search_labs_experiments_included": {"const": false}
      },
      "additionalProperties": false
    },
    "filterPair": {
      "type": "object",
      "required": ["baseline", "current"],
      "properties": {
        "baseline": {"$ref": "#/$defs/nullableString"},
        "current": {"$ref": "#/$defs/nullableString"}
      },
      "additionalProperties": false
    },
    "datasetContract": {
      "type": "object",
      "required": [
        "source_kind",
        "property_id",
        "search_type",
        "web_performance_relationship",
        "source_timezone",
        "source_timezone_label",
        "temporal_grain",
        "ui_row_limit",
        "current_grain",
        "baseline_grain",
        "grains_aligned",
        "filters",
        "filters_aligned",
        "windows_disjoint",
        "baseline_precedes_current",
        "window_lengths_aligned",
        "contract_complete"
      ],
      "properties": {
        "source_kind": {"const": "gsc_generative_ai_performance_csv"},
        "property_id": {"$ref": "#/$defs/nullableString"},
        "search_type": {"const": "web"},
        "web_performance_relationship": {"const": "subset_non_additive"},
        "source_timezone": {"const": "America/Los_Angeles"},
        "source_timezone_label": {"const": "PT"},
        "temporal_grain": {"const": "date"},
        "ui_row_limit": {"const": 1000},
        "current_grain": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/grainField"}
        },
        "baseline_grain": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/grainField"}
        },
        "grains_aligned": {"const": true},
        "filters": {"$ref": "#/$defs/filterPair"},
        "filters_aligned": {"const": true},
        "windows_disjoint": {"const": true},
        "baseline_precedes_current": {"const": true},
        "window_lengths_aligned": {"type": "boolean"},
        "contract_complete": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "period": {
      "type": "object",
      "required": [
        "label",
        "requested_start",
        "requested_end",
        "observed_start",
        "observed_end",
        "effective_start",
        "effective_end",
        "boundary_source",
        "calendar_days",
        "source"
      ],
      "properties": {
        "label": {"type": "string", "minLength": 1},
        "requested_start": {"$ref": "#/$defs/nullableString"},
        "requested_end": {"$ref": "#/$defs/nullableString"},
        "observed_start": {"$ref": "#/$defs/nullableString"},
        "observed_end": {"$ref": "#/$defs/nullableString"},
        "effective_start": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
        "effective_end": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
        "boundary_source": {"enum": ["declared", "observed"]},
        "calendar_days": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "source": {"$ref": "#/$defs/fileReference"}
      },
      "additionalProperties": false
    },
    "dimensionCoverage": {
      "type": "object",
      "required": ["column_present", "populated_rows", "blank_rows"],
      "properties": {
        "column_present": {"type": "boolean"},
        "populated_rows": {"$ref": "#/$defs/nonNegativeInteger"},
        "blank_rows": {"$ref": "#/$defs/nonNegativeInteger"}
      },
      "additionalProperties": false
    },
    "dimensionCoverageMap": {
      "type": "object",
      "required": ["page", "country", "device"],
      "properties": {
        "page": {"$ref": "#/$defs/dimensionCoverage"},
        "country": {"$ref": "#/$defs/dimensionCoverage"},
        "device": {"$ref": "#/$defs/dimensionCoverage"}
      },
      "additionalProperties": false
    },
    "windowCoverage": {
      "type": "object",
      "required": [
        "source_rows",
        "included_rows",
        "excluded_rows",
        "date_column_present",
        "observed_date_start",
        "observed_date_end",
        "zero_impression_rows",
        "normalized_placeholder_rows_in_source",
        "dimensions"
      ],
      "properties": {
        "source_rows": {"$ref": "#/$defs/nonNegativeInteger"},
        "included_rows": {"$ref": "#/$defs/nonNegativeInteger"},
        "excluded_rows": {"$ref": "#/$defs/nonNegativeInteger"},
        "date_column_present": {"type": "boolean"},
        "observed_date_start": {"$ref": "#/$defs/nullableString"},
        "observed_date_end": {"$ref": "#/$defs/nullableString"},
        "zero_impression_rows": {"$ref": "#/$defs/nonNegativeInteger"},
        "normalized_placeholder_rows_in_source": {"$ref": "#/$defs/nonNegativeInteger"},
        "dimensions": {"$ref": "#/$defs/dimensionCoverageMap"}
      },
      "additionalProperties": false
    },
    "coverage": {
      "type": "object",
      "required": ["baseline", "current", "shared_dimensions", "missing_dimensions"],
      "properties": {
        "baseline": {"$ref": "#/$defs/windowCoverage"},
        "current": {"$ref": "#/$defs/windowCoverage"},
        "shared_dimensions": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/dimension"}
        },
        "missing_dimensions": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/dimension"}
        }
      },
      "additionalProperties": false
    },
    "sourceIssue": {
      "type": "object",
      "required": ["code", "severity"],
      "properties": {
        "code": {"type": "string", "minLength": 1},
        "severity": {"enum": ["unknown", "limited"]}
      },
      "additionalProperties": false
    },
    "sourceQuality": {
      "type": "object",
      "required": ["status", "issues"],
      "properties": {
        "status": {"enum": ["complete", "unknown", "limited"]},
        "issues": {
          "type": "array",
          "items": {"$ref": "#/$defs/sourceIssue"}
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "complete"}}, "required": ["status"]},
          "then": {"properties": {"issues": {"maxItems": 0}}}
        },
        {
          "if": {"properties": {"status": {"enum": ["unknown", "limited"]}}, "required": ["status"]},
          "then": {"properties": {"issues": {"minItems": 1}}}
        }
      ]
    },
    "sourceBase": {
      "type": "object",
      "required": [
        "source_id",
        "path",
        "sha256",
        "source_kind",
        "property_id",
        "search_type",
        "web_performance_relationship",
        "source_timezone",
        "source_timezone_label",
        "data_as_of",
        "finality",
        "preliminary",
        "completeness",
        "ui_row_limit",
        "row_limit_hit",
        "source_rows_at_or_above_ui_limit",
        "filters",
        "source_rows",
        "included_rows",
        "quality"
      ],
      "properties": {
        "source_id": {"enum": ["baseline", "current"]},
        "path": {"$ref": "#/$defs/fileReference"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "source_kind": {"const": "gsc_generative_ai_performance_csv"},
        "property_id": {"$ref": "#/$defs/nullableString"},
        "search_type": {"const": "web"},
        "web_performance_relationship": {"const": "subset_non_additive"},
        "source_timezone": {"const": "America/Los_Angeles"},
        "source_timezone_label": {"const": "PT"},
        "data_as_of": {"$ref": "#/$defs/nullableOffsetDateTime"},
        "finality": {"enum": ["final", "preliminary", "unknown"]},
        "preliminary": {"type": "boolean"},
        "completeness": {"enum": ["complete", "incomplete", "unknown"]},
        "ui_row_limit": {"const": 1000},
        "row_limit_hit": {"type": ["boolean", "null"]},
        "source_rows_at_or_above_ui_limit": {"type": "boolean"},
        "filters": {"$ref": "#/$defs/nullableString"},
        "source_rows": {"$ref": "#/$defs/nonNegativeInteger"},
        "included_rows": {"$ref": "#/$defs/nonNegativeInteger"},
        "quality": {"$ref": "#/$defs/sourceQuality"}
      },
      "additionalProperties": false
    },
    "baselineSource": {
      "allOf": [
        {"$ref": "#/$defs/sourceBase"},
        {
          "type": "object",
          "properties": {"source_id": {"const": "baseline"}}
        }
      ]
    },
    "currentSource": {
      "allOf": [
        {"$ref": "#/$defs/sourceBase"},
        {
          "type": "object",
          "properties": {"source_id": {"const": "current"}}
        }
      ]
    },
    "reportIssue": {
      "type": "object",
      "required": ["source", "code", "severity"],
      "properties": {
        "source": {"enum": ["baseline", "current", "comparison"]},
        "code": {"type": "string", "minLength": 1},
        "severity": {"enum": ["unknown", "limited"]}
      },
      "additionalProperties": false
    },
    "reportQuality": {
      "type": "object",
      "required": ["status", "complete", "issues"],
      "properties": {
        "status": {"enum": ["complete", "unknown", "limited"]},
        "complete": {"type": "boolean"},
        "issues": {
          "type": "array",
          "items": {"$ref": "#/$defs/reportIssue"}
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "complete"}}, "required": ["status"]},
          "then": {
            "properties": {"complete": {"const": true}, "issues": {"maxItems": 0}}
          }
        },
        {
          "if": {"properties": {"status": {"enum": ["unknown", "limited"]}}, "required": ["status"]},
          "then": {
            "properties": {"complete": {"const": false}, "issues": {"minItems": 1}}
          }
        },
        {
          "if": {"properties": {"complete": {"const": true}}, "required": ["complete"]},
          "then": {"properties": {"status": {"const": "complete"}}}
        }
      ]
    },
    "verdictEligibility": {
      "type": "object",
      "required": [
        "recommended_verdict",
        "maximum_supported_verdict",
        "causal_or_incremental_claim_allowed",
        "reasons"
      ],
      "properties": {
        "recommended_verdict": {"enum": ["descriptive", "inconclusive"]},
        "maximum_supported_verdict": {"const": "descriptive"},
        "causal_or_incremental_claim_allowed": {"const": false},
        "reasons": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      },
      "additionalProperties": false
    },
    "metrics": {
      "type": "object",
      "required": ["impressions", "rows", "zero_impression_rows"],
      "properties": {
        "impressions": {"$ref": "#/$defs/nonNegativeNumber"},
        "rows": {"$ref": "#/$defs/nonNegativeInteger"},
        "zero_impression_rows": {"$ref": "#/$defs/nonNegativeInteger"}
      },
      "additionalProperties": false
    },
    "delta": {
      "type": "object",
      "required": [
        "impressions_absolute",
        "impressions_relative",
        "impressions_relative_reason"
      ],
      "properties": {
        "impressions_absolute": {"type": "number"},
        "impressions_relative": {"type": ["number", "null"]},
        "impressions_relative_reason": {
          "enum": ["baseline_impressions_zero", null]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {"impressions_relative": {"type": "null"}},
            "required": ["impressions_relative"]
          },
          "then": {
            "properties": {
              "impressions_relative_reason": {"const": "baseline_impressions_zero"}
            }
          },
          "else": {
            "properties": {"impressions_relative_reason": {"type": "null"}}
          }
        }
      ],
      "additionalProperties": false
    },
    "overall": {
      "type": "object",
      "required": ["label", "baseline", "current", "delta"],
      "properties": {
        "label": {"type": "string", "minLength": 1},
        "baseline": {"$ref": "#/$defs/metrics"},
        "current": {"$ref": "#/$defs/metrics"},
        "delta": {"$ref": "#/$defs/delta"}
      },
      "additionalProperties": false
    },
    "cohortRow": {
      "type": "object",
      "required": ["value", "baseline", "current", "delta"],
      "properties": {
        "value": {"type": "string", "minLength": 1},
        "baseline": {"$ref": "#/$defs/metrics"},
        "current": {"$ref": "#/$defs/metrics"},
        "delta": {"$ref": "#/$defs/delta"}
      },
      "additionalProperties": false
    },
    "cohort": {
      "type": "object",
      "required": [
        "label",
        "available",
        "unavailable_reason",
        "groups_total",
        "groups_returned",
        "rows"
      ],
      "properties": {
        "label": {"type": "string", "minLength": 1},
        "available": {"type": "boolean"},
        "unavailable_reason": {
          "enum": ["dimension_not_present_in_both_periods", null]
        },
        "groups_total": {"$ref": "#/$defs/nonNegativeInteger"},
        "groups_returned": {"$ref": "#/$defs/nonNegativeInteger"},
        "rows": {
          "type": "array",
          "items": {"$ref": "#/$defs/cohortRow"}
        }
      },
      "additionalProperties": false
    }
  }
}
