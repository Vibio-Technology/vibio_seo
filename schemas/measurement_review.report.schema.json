{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.vibio.local/measurement_review.report/1.2/schema.json",
  "title": "Vibio SEO 多来源业务复盘报告",
  "description": "runtime/measurement_review.py 输出的 GSC、GA4 与 CRM 聚合复盘、时区和数据完整性契约。",
  "type": "object",
  "required": [
    "schema_version",
    "tool",
    "generated_at",
    "sources",
    "contract",
    "quality",
    "data_quality",
    "coverage",
    "window_totals",
    "window_deltas",
    "landing_page_cohorts",
    "join_limitations",
    "verdict_eligibility"
  ],
  "properties": {
    "schema_version": {"const": "1.2"},
    "tool": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": {"const": "vibio-seo-measurement-review"},
        "version": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "generated_at": {"type": "string", "minLength": 1},
    "sources": {
      "type": "object",
      "required": ["mapping", "gsc_page"],
      "properties": {
        "mapping": {"$ref": "#/$defs/mappingSource"},
        "gsc_page": {"$ref": "#/$defs/dataSource"},
        "ga4": {"$ref": "#/$defs/dataSource"},
        "crm": {"$ref": "#/$defs/dataSource"}
      },
      "additionalProperties": false
    },
    "contract": {"$ref": "#/$defs/contract"},
    "quality": {
      "type": "object",
      "required": ["gsc_page"],
      "additionalProperties": {"$ref": "#/$defs/sourceQuality"}
    },
    "data_quality": {"$ref": "#/$defs/reportDataQuality"},
    "coverage": {
      "type": "object",
      "required": ["unmapped"],
      "properties": {
        "unmapped": {
          "type": "object",
          "required": ["gsc_page"],
          "additionalProperties": {
            "type": "object",
            "required": ["baseline", "current"],
            "properties": {
              "baseline": {"$ref": "#/$defs/mappingCoverage"},
              "current": {"$ref": "#/$defs/mappingCoverage"}
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "window_totals": {"$ref": "#/$defs/windowBundles"},
    "window_deltas": {
      "type": "object",
      "required": ["gsc_page"],
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {"$ref": "#/$defs/metricDelta"}
      }
    },
    "landing_page_cohorts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["landing_page", "sources"],
        "properties": {
          "landing_page": {"type": "string", "minLength": 1},
          "sources": {"type": "object", "minProperties": 1}
        },
        "additionalProperties": true
      }
    },
    "join_limitations": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "verdict_eligibility": {"$ref": "#/$defs/verdict"}
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "data_quality": {
            "properties": {"complete": {"const": true}},
            "required": ["complete"]
          }
        },
        "required": ["data_quality"]
      },
      "then": {
        "properties": {
          "contract": {
            "properties": {"contract_complete": {"const": true}},
            "required": ["contract_complete"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "data_quality": {
            "properties": {"complete": {"const": false}},
            "required": ["complete"]
          }
        },
        "required": ["data_quality"]
      },
      "then": {
        "properties": {
          "contract": {
            "properties": {"contract_complete": {"const": false}},
            "required": ["contract_complete"]
          }
        }
      }
    }
  ],
  "$defs": {
    "nullableString": {"type": ["string", "null"]},
    "nullableOffsetDateTime": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "string",
          "format": "date-time",
          "pattern": "(?:[Zz]|[+-][0-9]{2}:[0-9]{2})$"
        }
      ]
    },
    "nullableNumber": {"type": ["number", "null"]},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "fileReference": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*\\\\)(?![A-Za-z][A-Za-z0-9+.-]*:)(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+"
    },
    "issue": {
      "type": "object",
      "required": ["code", "source", "detail"],
      "properties": {
        "code": {"type": "string", "minLength": 1},
        "source": {"type": "string", "minLength": 1},
        "detail": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "sourceDataQuality": {
      "type": "object",
      "required": ["declared", "status", "issues"],
      "properties": {
        "declared": {"enum": ["complete", "degraded", "unknown"]},
        "status": {"enum": ["complete", "degraded", "unknown"]},
        "issues": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "complete"}}, "required": ["status"]},
          "then": {"properties": {"issues": {"maxItems": 0}}}
        },
        {
          "if": {"properties": {"status": {"enum": ["degraded", "unknown"]}}, "required": ["status"]},
          "then": {"properties": {"issues": {"minItems": 1}}}
        }
      ]
    },
    "mappingSource": {
      "type": "object",
      "required": ["label", "path", "sha256"],
      "properties": {
        "label": {"type": "string", "minLength": 1},
        "path": {"$ref": "#/$defs/fileReference"},
        "sha256": {"$ref": "#/$defs/sha256"}
      },
      "additionalProperties": false
    },
    "dataSource": {
      "type": "object",
      "required": [
        "label", "path", "sha256", "rows", "headers", "temporal_grain",
        "source_kind", "source_timezone", "data_as_of", "finality", "preliminary",
        "row_limit_hit", "pagination_complete", "sampling_rate",
        "thresholding_applied", "data_quality", "attribution_model"
      ],
      "properties": {
        "label": {"type": "string", "minLength": 1},
        "path": {"$ref": "#/$defs/fileReference"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "rows": {"type": "integer", "minimum": 1},
        "headers": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "temporal_grain": {"enum": ["date", "timestamp", "mixed", "unknown"]},
        "source_kind": {"type": "string", "minLength": 1},
        "source_timezone": {"$ref": "#/$defs/nullableString"},
        "data_as_of": {"$ref": "#/$defs/nullableOffsetDateTime"},
        "finality": {"enum": ["final", "preliminary", "unknown"]},
        "preliminary": {"type": "boolean"},
        "row_limit_hit": {"type": ["boolean", "null"]},
        "pagination_complete": {"type": ["boolean", "null"]},
        "sampling_rate": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "thresholding_applied": {"type": ["boolean", "null"]},
        "data_quality": {"$ref": "#/$defs/sourceDataQuality"},
        "attribution_model": {"$ref": "#/$defs/nullableString"}
      },
      "additionalProperties": false
    },
    "window": {
      "type": "object",
      "required": ["start", "end", "days"],
      "properties": {
        "start": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
        "end": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
        "days": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "alignment": {
      "type": "object",
      "required": [
        "mode", "daily_join_allowed", "window_aggregation_allowed",
        "analysis_timezone", "source_timezones", "source_temporal_grains", "issues"
      ],
      "properties": {
        "mode": {"enum": ["single_source", "timestamp_normalized_daily_join", "source_date_daily_join", "window_aggregate_only"]},
        "daily_join_allowed": {"type": "boolean"},
        "window_aggregation_allowed": {"const": true},
        "analysis_timezone": {"type": "string", "minLength": 1},
        "source_timezones": {"type": "object", "additionalProperties": {"$ref": "#/$defs/nullableString"}},
        "source_temporal_grains": {"type": "object", "additionalProperties": {"enum": ["date", "timestamp", "mixed", "unknown"]}},
        "issues": {"type": "array", "items": {"$ref": "#/$defs/issue"}}
      },
      "additionalProperties": false
    },
    "contract": {
      "type": "object",
      "required": [
        "property", "search_type", "timezone", "analysis_timezone", "source_timezones",
        "source_temporal_grains", "cross_source_join", "windows", "allowed_shared_dimensions",
        "source_grains", "dimension_mapping", "metric_mapping", "value_mapping",
        "url_normalization", "crm_definition", "query_columns_allowed",
        "user_level_or_pii_columns_allowed", "missing_values_imputed_as_zero", "contract_complete"
      ],
      "properties": {
        "property": {"type": "string", "minLength": 1},
        "search_type": {"type": "string", "minLength": 1},
        "timezone": {"type": "string", "minLength": 1},
        "analysis_timezone": {"type": "string", "minLength": 1},
        "source_timezones": {"type": "object", "additionalProperties": {"$ref": "#/$defs/nullableString"}},
        "source_temporal_grains": {"type": "object", "additionalProperties": {"enum": ["date", "timestamp", "mixed", "unknown"]}},
        "cross_source_join": {"$ref": "#/$defs/alignment"},
        "windows": {
          "type": "object",
          "required": ["baseline", "current", "inclusive", "disjoint"],
          "properties": {
            "baseline": {"$ref": "#/$defs/window"},
            "current": {"$ref": "#/$defs/window"},
            "inclusive": {"const": true},
            "disjoint": {"const": true}
          },
          "additionalProperties": false
        },
        "allowed_shared_dimensions": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "source_grains": {"type": "object"},
        "dimension_mapping": {"type": "object"},
        "metric_mapping": {"type": "object"},
        "value_mapping": {"type": "object"},
        "url_normalization": {"type": "object"},
        "crm_definition": {"type": "object"},
        "query_columns_allowed": {"const": false},
        "user_level_or_pii_columns_allowed": {"const": false},
        "missing_values_imputed_as_zero": {"const": false},
        "contract_complete": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "sourceQuality": {
      "type": "object",
      "required": [
        "source_kind", "source_timezone", "temporal_grain", "metadata_status",
        "source_rows", "window_rows", "blank_or_invalid_dimensions", "blank_metrics",
        "full_grain_eligible_rows", "duplicate_grain_groups", "duplicate_grain_rows", "ignored_columns",
        "gate_status", "issues"
      ],
      "properties": {
        "source_kind": {"type": "string", "minLength": 1},
        "source_timezone": {"$ref": "#/$defs/nullableString"},
        "temporal_grain": {"enum": ["date", "timestamp", "mixed", "unknown"]},
        "metadata_status": {"enum": ["complete", "degraded", "unknown"]},
        "source_rows": {"type": "integer", "minimum": 1},
        "window_rows": {"type": "object"},
        "blank_or_invalid_dimensions": {"type": "object"},
        "blank_metrics": {"type": "object"},
        "full_grain_eligible_rows": {"type": "integer", "minimum": 0},
        "duplicate_grain_groups": {"type": "integer", "minimum": 0},
        "duplicate_grain_rows": {"type": "integer", "minimum": 0},
        "ignored_columns": {"type": "array", "items": {"type": "string"}},
        "gate_status": {"enum": ["complete", "inconclusive"]},
        "issues": {"type": "array", "items": {"$ref": "#/$defs/issue"}}
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {"properties": {"gate_status": {"const": "complete"}}, "required": ["gate_status"]},
          "then": {"properties": {"issues": {"maxItems": 0}}}
        },
        {
          "if": {"properties": {"gate_status": {"const": "inconclusive"}}, "required": ["gate_status"]},
          "then": {"properties": {"issues": {"minItems": 1}}}
        }
      ]
    },
    "reportDataQuality": {
      "type": "object",
      "required": ["status", "complete", "issues"],
      "properties": {
        "status": {"enum": ["complete", "inconclusive"]},
        "complete": {"type": "boolean"},
        "issues": {"type": "array", "items": {"$ref": "#/$defs/issue"}}
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "complete"}}, "required": ["status"]},
          "then": {
            "properties": {"complete": {"const": true}, "issues": {"maxItems": 0}}
          }
        },
        {
          "if": {"properties": {"status": {"const": "inconclusive"}}, "required": ["status"]},
          "then": {
            "properties": {"complete": {"const": false}, "issues": {"minItems": 1}}
          }
        },
        {
          "if": {"properties": {"complete": {"const": true}}, "required": ["complete"]},
          "then": {"properties": {"status": {"const": "complete"}}}
        }
      ]
    },
    "observation": {
      "type": "object",
      "required": ["value", "reason"],
      "properties": {
        "value": {"$ref": "#/$defs/nullableNumber"},
        "reason": {
          "oneOf": [
            {"type": "null"},
            {
              "type": "object",
              "required": ["code", "message"],
              "properties": {
                "code": {"type": "string", "minLength": 1},
                "message": {"type": "string", "minLength": 1}
              },
              "additionalProperties": false
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "metricBundle": {
      "type": "object",
      "required": ["rows", "metrics"],
      "properties": {
        "rows": {"type": "integer", "minimum": 0},
        "metrics": {"type": "object", "minProperties": 1, "additionalProperties": {"$ref": "#/$defs/observation"}}
      },
      "additionalProperties": false
    },
    "windowBundles": {
      "type": "object",
      "required": ["baseline", "current"],
      "properties": {
        "baseline": {"type": "object", "required": ["gsc_page"], "additionalProperties": {"$ref": "#/$defs/metricBundle"}},
        "current": {"type": "object", "required": ["gsc_page"], "additionalProperties": {"$ref": "#/$defs/metricBundle"}}
      },
      "additionalProperties": false
    },
    "metricDelta": {
      "type": "object",
      "required": ["absolute", "relative"],
      "properties": {
        "absolute": {"$ref": "#/$defs/observation"},
        "relative": {"$ref": "#/$defs/observation"}
      },
      "additionalProperties": false
    },
    "mappingCoverage": {
      "type": "object",
      "required": [
        "key_dimensions", "rows", "eligible_rows", "matched_rows", "unmatched_rows",
        "blank_or_invalid_grain_rows", "explicit_url_mapping_rows", "matched_rate",
        "unmatched_landing_page_examples", "join_performed", "join_reason"
      ],
      "properties": {
        "key_dimensions": {"type": "array", "items": {"type": "string"}},
        "rows": {"type": "integer", "minimum": 0},
        "eligible_rows": {"type": "integer", "minimum": 0},
        "matched_rows": {"type": ["integer", "null"], "minimum": 0},
        "unmatched_rows": {"type": ["integer", "null"], "minimum": 0},
        "blank_or_invalid_grain_rows": {"type": "integer", "minimum": 0},
        "explicit_url_mapping_rows": {"type": "integer", "minimum": 0},
        "matched_rate": {"$ref": "#/$defs/observation"},
        "unmatched_landing_page_examples": {"type": "array", "items": {"type": "string"}},
        "join_performed": {"type": "boolean"},
        "join_reason": {"$ref": "#/$defs/nullableString"}
      },
      "additionalProperties": false
    },
    "verdict": {
      "type": "object",
      "required": [
        "recommended_verdict", "maximum_supported_verdict", "directional_eligible",
        "causal_inference_eligible", "automatic_causal_or_incrementality_claim_allowed",
        "incremental_positive_allowed", "no_detectable_change_allowed",
        "eligibility_reasons", "boundary"
      ],
      "properties": {
        "recommended_verdict": {"enum": ["directional", "inconclusive"]},
        "maximum_supported_verdict": {"const": "directional"},
        "directional_eligible": {"type": "boolean"},
        "causal_inference_eligible": {"const": false},
        "automatic_causal_or_incrementality_claim_allowed": {"const": false},
        "incremental_positive_allowed": {"const": false},
        "no_detectable_change_allowed": {"const": false},
        "eligibility_reasons": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "boundary": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {"properties": {"directional_eligible": {"const": true}}, "required": ["directional_eligible"]},
          "then": {"properties": {"recommended_verdict": {"const": "directional"}}}
        },
        {
          "if": {"properties": {"directional_eligible": {"const": false}}, "required": ["directional_eligible"]},
          "then": {"properties": {"recommended_verdict": {"const": "inconclusive"}}}
        }
      ]
    }
  }
}
