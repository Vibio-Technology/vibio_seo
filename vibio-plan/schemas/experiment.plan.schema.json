{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.vibio.local/experiment.plan.schema.json",
  "title": "Vibio SEO 冻结实验计划",
  "description": "runtime/experiment.py plan 子命令生成的预注册、稳定分组与输入指纹契约。跨字段 hash 和分组唯一性仍由工具内部校验器验证。",
  "type": "object",
  "required": [
    "schema_version",
    "tool",
    "experiment_id",
    "design",
    "unit_id_column",
    "preregistration",
    "frozen_inputs",
    "measurement_contract",
    "assignments",
    "assignments_sha256",
    "balance",
    "boundaries",
    "plan_hash"
  ],
  "properties": {
    "schema_version": {"const": "1.1"},
    "tool": {"const": "vibio-seo-experiment"},
    "experiment_id": {"type": "string", "minLength": 1},
    "design": {"enum": ["randomized_page_holdout", "matched_page_did"]},
    "unit_id_column": {"type": "string", "minLength": 1},
    "preregistration": {"$ref": "#/$defs/preregistration"},
    "frozen_inputs": {"$ref": "#/$defs/frozenInputs"},
    "measurement_contract": {"$ref": "#/$defs/measurementContract"},
    "assignments": {
      "type": "array",
      "minItems": 2,
      "items": {"$ref": "#/$defs/assignment"},
      "allOf": [
        {
          "contains": {
            "type": "object",
            "properties": {"group": {"const": "treatment"}},
            "required": ["group"]
          },
          "minContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {"group": {"const": "control"}},
            "required": ["group"]
          },
          "minContains": 1
        }
      ]
    },
    "assignments_sha256": {"$ref": "#/$defs/sha256"},
    "balance": {"$ref": "#/$defs/balance"},
    "boundaries": {"$ref": "#/$defs/boundaries"},
    "plan_hash": {"$ref": "#/$defs/sha256"}
  },
  "allOf": [
    {
      "if": {
        "properties": {"design": {"const": "matched_page_did"}},
        "required": ["design"]
      },
      "then": {
        "properties": {
          "assignments": {
            "items": {
              "type": "object",
              "required": ["unit_id", "group", "pair_id"]
            }
          }
        }
      }
    }
  ],
  "additionalProperties": true,
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    "window": {
      "type": "object",
      "required": ["start", "end"],
      "properties": {
        "start": {"$ref": "#/$defs/date"},
        "end": {"$ref": "#/$defs/date"}
      },
      "additionalProperties": true
    },
    "guardrail": {
      "type": "object",
      "required": ["metric", "direction", "threshold", "scale"],
      "properties": {
        "metric": {"type": "string", "minLength": 1},
        "direction": {"enum": ["non_decrease", "non_increase"]},
        "threshold": {"type": "number", "minimum": 0},
        "scale": {"const": "absolute_did"}
      },
      "additionalProperties": true
    },
    "preregistration": {
      "type": "object",
      "required": [
        "primary_metric",
        "primary_metric_direction",
        "guardrails",
        "seed",
        "treatment_fraction",
        "baseline_window",
        "observation_window",
        "minimum_detectable_effect",
        "alpha"
      ],
      "properties": {
        "primary_metric": {"type": "string", "minLength": 1},
        "primary_metric_direction": {"enum": ["increase", "decrease"]},
        "guardrails": {
          "type": "array",
          "items": {"$ref": "#/$defs/guardrail"}
        },
        "seed": {
          "oneOf": [
            {"type": "integer"},
            {"type": "string", "minLength": 1}
          ]
        },
        "treatment_fraction": {
          "type": "number",
          "exclusiveMinimum": 0,
          "exclusiveMaximum": 1
        },
        "baseline_window": {"$ref": "#/$defs/window"},
        "observation_window": {"$ref": "#/$defs/window"},
        "minimum_detectable_effect": {
          "type": "object",
          "required": ["value", "scale"],
          "properties": {
            "value": {"type": "number", "exclusiveMinimum": 0},
            "scale": {"enum": ["absolute", "relative_to_control_baseline"]}
          },
          "additionalProperties": true
        },
        "alpha": {
          "type": "number",
          "exclusiveMinimum": 0,
          "exclusiveMaximum": 1
        }
      },
      "additionalProperties": true
    },
    "frozenInputs": {
      "type": "object",
      "required": [
        "spec_sha256",
        "baseline_sha256",
        "baseline_source_rows",
        "baseline_temporal_grain",
        "baseline_units",
        "baseline_units_sha256"
      ],
      "properties": {
        "spec_sha256": {"$ref": "#/$defs/sha256"},
        "baseline_sha256": {"$ref": "#/$defs/sha256"},
        "baseline_source_rows": {"type": "integer", "minimum": 1},
        "baseline_temporal_grain": {"enum": ["date", "window_aggregate"]},
        "baseline_units": {
          "type": "array",
          "minItems": 2,
          "items": {"$ref": "#/$defs/baselineUnit"}
        },
        "baseline_units_sha256": {"$ref": "#/$defs/sha256"}
      },
      "additionalProperties": true
    },
    "baselineUnit": {
      "type": "object",
      "required": ["unit_id", "pair_id", "metrics", "source_rows", "dates"],
      "properties": {
        "unit_id": {"type": "string", "minLength": 1},
        "pair_id": {"type": ["string", "null"]},
        "metrics": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {"type": "number"}
        },
        "source_rows": {"type": "integer", "minimum": 1},
        "dates": {
          "type": "array",
          "items": {"$ref": "#/$defs/date"},
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "qualityIssue": {
      "type": "object",
      "required": ["code", "source", "detail"],
      "properties": {
        "code": {"type": "string", "minLength": 1},
        "source": {"type": "string", "minLength": 1},
        "detail": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "sourceDataQuality": {
      "type": "object",
      "required": ["declared", "status", "issues"],
      "properties": {
        "declared": {"enum": ["complete", "degraded", "unknown"]},
        "status": {"enum": ["complete", "degraded", "unknown"]},
        "issues": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
      },
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "complete"}}, "required": ["status"]},
          "then": {"properties": {"declared": {"const": "complete"}, "issues": {"maxItems": 0}}}
        },
        {
          "if": {"properties": {"status": {"enum": ["degraded", "unknown"]}}, "required": ["status"]},
          "then": {"properties": {"issues": {"minItems": 1}}}
        }
      ],
      "additionalProperties": false
    },
    "measurementSource": {
      "type": "object",
      "required": [
        "source_id", "source_kind", "source_timezone", "metrics", "data_as_of",
        "finality", "preliminary", "row_limit_hit", "pagination_complete",
        "sampling_rate", "thresholding_applied", "data_quality", "attribution_model"
      ],
      "properties": {
        "source_id": {"type": "string", "minLength": 1},
        "source_kind": {"type": "string", "minLength": 1},
        "source_timezone": {"type": ["string", "null"]},
        "metrics": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
        "data_as_of": {"type": ["string", "null"]},
        "finality": {"enum": ["final", "preliminary", "unknown"]},
        "preliminary": {"type": "boolean"},
        "row_limit_hit": {"type": ["boolean", "null"]},
        "pagination_complete": {"type": ["boolean", "null"]},
        "sampling_rate": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "thresholding_applied": {"type": ["boolean", "null"]},
        "data_quality": {"$ref": "#/$defs/sourceDataQuality"},
        "attribution_model": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    },
    "measurementContract": {
      "type": "object",
      "required": [
        "analysis_timezone", "temporal_grain", "source_timezones",
        "daily_cross_source_join_allowed", "window_aggregation_allowed", "sources", "issues"
      ],
      "properties": {
        "analysis_timezone": {"type": ["string", "null"]},
        "temporal_grain": {"const": "date"},
        "source_timezones": {"type": "object", "additionalProperties": {"type": ["string", "null"]}},
        "daily_cross_source_join_allowed": {"type": "boolean"},
        "window_aggregation_allowed": {"const": true},
        "sources": {"type": "object", "additionalProperties": {"$ref": "#/$defs/measurementSource"}},
        "issues": {"type": "array", "items": {"$ref": "#/$defs/qualityIssue"}}
      },
      "additionalProperties": false
    },
    "assignment": {
      "type": "object",
      "required": ["unit_id", "group"],
      "properties": {
        "unit_id": {"type": "string", "minLength": 1},
        "group": {"enum": ["treatment", "control"]},
        "pair_id": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "balanceMetric": {
      "type": "object",
      "required": [
        "treatment_mean",
        "control_mean",
        "absolute_difference",
        "standardized_difference",
        "note"
      ],
      "properties": {
        "treatment_mean": {"type": "number"},
        "control_mean": {"type": "number"},
        "absolute_difference": {"type": "number"},
        "standardized_difference": {"type": ["number", "null"]},
        "note": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "balance": {
      "type": "object",
      "required": ["unit_counts", "metrics"],
      "properties": {
        "unit_counts": {
          "type": "object",
          "required": ["treatment", "control"],
          "properties": {
            "treatment": {"type": "integer", "minimum": 1},
            "control": {"type": "integer", "minimum": 1}
          },
          "additionalProperties": {"type": "integer", "minimum": 0}
        },
        "metrics": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {"$ref": "#/$defs/balanceMetric"}
        }
      },
      "additionalProperties": true
    },
    "boundaries": {
      "type": "object",
      "required": ["causality", "paid_search", "power"],
      "properties": {
        "causality": {"type": "string", "minLength": 1},
        "paid_search": {"type": "string", "minLength": 1},
        "power": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    }
  }
}
