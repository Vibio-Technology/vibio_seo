{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.vibio.local/experiment.report.schema.json",
  "title": "Vibio SEO 实验增量资格报告",
  "description": "runtime/experiment.py analyze 子命令生成的页面级 DiD、数据质量、护栏与增量解读资格契约。eligible_incremental 不是自动因果或业务结论。",
  "type": "object",
  "required": [
    "schema_version",
    "tool",
    "experiment_id",
    "design",
    "plan_hash",
    "analyzed_at",
    "source_hashes",
    "windows",
    "artifact_verification",
    "measurement_contract",
    "data_quality",
    "metrics",
    "primary_metric",
    "guardrails",
    "eligibility",
    "eligibility_details",
    "methodology"
  ],
  "properties": {
    "schema_version": {"const": "1.1"},
    "tool": {"const": "vibio-seo-experiment"},
    "experiment_id": {"type": "string", "minLength": 1},
    "design": {"enum": ["randomized_page_holdout", "matched_page_did"]},
    "plan_hash": {"$ref": "#/$defs/sha256"},
    "analyzed_at": {"type": "string", "minLength": 1},
    "source_hashes": {"$ref": "#/$defs/sourceHashes"},
    "windows": {
      "type": "object",
      "required": ["baseline", "observation"],
      "properties": {
        "baseline": {"$ref": "#/$defs/window"},
        "observation": {"$ref": "#/$defs/window"}
      },
      "additionalProperties": false
    },
    "artifact_verification": {"$ref": "#/$defs/artifactVerification"},
    "measurement_contract": {"$ref": "#/$defs/measurementContract"},
    "data_quality": {"$ref": "#/$defs/dataQuality"},
    "metrics": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"$ref": "#/$defs/metricEstimate"}
    },
    "primary_metric": {"$ref": "#/$defs/metricEstimate"},
    "guardrails": {"$ref": "#/$defs/guardrails"},
    "eligibility": {
      "enum": ["eligible_incremental", "implementation-failed", "inconclusive"]
    },
    "eligibility_details": {"$ref": "#/$defs/eligibilityDetails"},
    "methodology": {"$ref": "#/$defs/methodology"}
  },
  "allOf": [
    {
      "if": {"properties": {"eligibility": {"const": "eligible_incremental"}}, "required": ["eligibility"]},
      "then": {
        "properties": {
          "artifact_verification": {"properties": {"passed": {"const": true}, "status": {"const": "passed"}}},
          "data_quality": {"properties": {"passed": {"const": true}}},
          "measurement_contract": {"properties": {"complete": {"const": true}, "status": {"const": "complete"}}},
          "guardrails": {"properties": {"passed": {"const": true}}},
          "eligibility_details": {"properties": {"eligible_incremental": {"const": true}, "reasons": {"maxItems": 0}}}
        }
      }
    },
    {
      "if": {"properties": {"eligibility": {"const": "implementation-failed"}}, "required": ["eligibility"]},
      "then": {
        "properties": {
          "artifact_verification": {"properties": {"passed": {"const": false}, "status": {"const": "failed"}}},
          "eligibility_details": {"properties": {"eligible_incremental": {"const": false}, "reasons": {"minItems": 1}}}
        }
      }
    },
    {
      "if": {"properties": {"eligibility": {"const": "inconclusive"}}, "required": ["eligibility"]},
      "then": {"properties": {"eligibility_details": {"properties": {"eligible_incremental": {"const": false}, "reasons": {"minItems": 1}}}}}
    }
  ],
  "additionalProperties": false,
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "nullableNumber": {"type": ["number", "null"]},
    "date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    "window": {
      "type": "object",
      "required": ["start", "end"],
      "properties": {
        "start": {"$ref": "#/$defs/date"},
        "end": {"$ref": "#/$defs/date"}
      },
      "additionalProperties": false
    },
    "sourceHashes": {
      "type": "object",
      "required": [
        "plan_file_sha256",
        "panel_sha256",
        "artifact_report_sha256",
        "measurement_metadata_sha256",
        "spec_sha256",
        "baseline_sha256",
        "baseline_source_rows",
        "baseline_temporal_grain",
        "baseline_units_sha256"
      ],
      "properties": {
        "plan_file_sha256": {"$ref": "#/$defs/sha256"},
        "panel_sha256": {"$ref": "#/$defs/sha256"},
        "artifact_report_sha256": {"$ref": "#/$defs/sha256"},
        "measurement_metadata_sha256": {
          "oneOf": [
            {"$ref": "#/$defs/sha256"},
            {"type": "null"}
          ]
        },
        "spec_sha256": {"$ref": "#/$defs/sha256"},
        "baseline_sha256": {"$ref": "#/$defs/sha256"},
        "baseline_source_rows": {"type": "integer", "minimum": 1},
        "baseline_temporal_grain": {"enum": ["date", "window_aggregate"]},
        "baseline_units_sha256": {"$ref": "#/$defs/sha256"}
      },
      "additionalProperties": false
    },
    "artifactVerification": {
      "type": "object",
      "required": ["experiment_id", "plan_hash", "passed", "status", "evidence"],
      "properties": {
        "experiment_id": {"type": "string", "minLength": 1},
        "plan_hash": {"$ref": "#/$defs/sha256"},
        "passed": {"type": ["boolean", "null"]},
        "status": {"enum": ["passed", "failed", "unverified"]},
        "evidence": {
          "oneOf": [
            {"type": "string", "minLength": 1},
            {"type": "array", "minItems": 1},
            {"type": "object", "minProperties": 1}
          ]
        }
      },
      "allOf": [
        {
          "if": {"properties": {"passed": {"const": true}}, "required": ["passed"]},
          "then": {"properties": {"status": {"const": "passed"}}}
        },
        {
          "if": {"properties": {"passed": {"const": false}}, "required": ["passed"]},
          "then": {"properties": {"status": {"const": "failed"}}}
        },
        {
          "if": {"properties": {"passed": {"type": "null"}}, "required": ["passed"]},
          "then": {"properties": {"status": {"const": "unverified"}}}
        }
      ],
      "additionalProperties": false
    },
    "issue": {
      "type": "object",
      "required": ["code"],
      "properties": {
        "code": {"type": "string", "minLength": 1},
        "detail": {"type": "string", "minLength": 1},
        "row": {"type": "integer", "minimum": 2},
        "unit_id": {"type": "string", "minLength": 1},
        "date": {"$ref": "#/$defs/date"},
        "periods": {
          "type": "array",
          "items": {"enum": ["baseline", "current"]},
          "uniqueItems": true
        },
        "expected_applied": {"type": "boolean"},
        "observation_end": {"$ref": "#/$defs/date"},
        "as_of": {"$ref": "#/$defs/date"},
        "metric": {"type": "string", "minLength": 1},
        "source": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "dataQuality": {
      "type": "object",
      "required": ["passed", "contamination_observable", "coverage", "issues"],
      "properties": {
        "passed": {"type": "boolean"},
        "contamination_observable": {"type": "boolean"},
        "coverage": {"$ref": "#/$defs/coverage"},
        "issues": {
          "type": "array",
          "items": {"$ref": "#/$defs/issue"}
        }
      },
      "allOf": [
        {
          "if": {"properties": {"passed": {"const": true}}, "required": ["passed"]},
          "then": {"properties": {"coverage": {"properties": {"complete": {"const": true}, "frozen_baseline_bound": {"const": true}}}, "issues": {"maxItems": 0}}}
        },
        {
          "if": {"properties": {"passed": {"const": false}}, "required": ["passed"]},
          "then": {"properties": {"issues": {"minItems": 1}}}
        }
      ],
      "additionalProperties": false
    },
    "coveragePeriod": {
      "type": "object",
      "required": ["expected_dates", "expected_unit_days", "observed_unit_days", "complete"],
      "properties": {
        "expected_dates": {"type": "integer", "minimum": 1},
        "expected_unit_days": {"type": "integer", "minimum": 1},
        "observed_unit_days": {"type": "integer", "minimum": 0},
        "complete": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "coverage": {
      "type": "object",
      "required": ["temporal_grain", "expected_units", "periods", "complete", "frozen_baseline_bound"],
      "properties": {
        "temporal_grain": {"const": "date"},
        "expected_units": {"type": "integer", "minimum": 2},
        "periods": {
          "type": "object",
          "required": ["baseline", "current"],
          "properties": {
            "baseline": {"$ref": "#/$defs/coveragePeriod"},
            "current": {"$ref": "#/$defs/coveragePeriod"}
          },
          "additionalProperties": false
        },
        "complete": {"type": "boolean"},
        "frozen_baseline_bound": {"type": "boolean"}
      },
      "allOf": [
        {
          "if": {"properties": {"complete": {"const": true}}, "required": ["complete"]},
          "then": {"properties": {"periods": {"properties": {"baseline": {"properties": {"complete": {"const": true}}}, "current": {"properties": {"complete": {"const": true}}}}}}}
        },
        {
          "if": {"properties": {"complete": {"const": false}}, "required": ["complete"]},
          "then": {"properties": {"periods": {"anyOf": [{"properties": {"baseline": {"properties": {"complete": {"const": false}}}}}, {"properties": {"current": {"properties": {"complete": {"const": false}}}}}]}}}
        }
      ],
      "additionalProperties": false
    },
    "sourceDataQuality": {
      "type": "object",
      "required": ["declared", "status", "issues"],
      "properties": {
        "declared": {"enum": ["complete", "degraded", "unknown"]},
        "status": {"enum": ["complete", "degraded", "unknown"]},
        "issues": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      },
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "complete"}}, "required": ["status"]},
          "then": {"properties": {"declared": {"const": "complete"}, "issues": {"maxItems": 0}}}
        },
        {
          "if": {"properties": {"status": {"enum": ["degraded", "unknown"]}}, "required": ["status"]},
          "then": {"properties": {"issues": {"minItems": 1}}}
        }
      ],
      "additionalProperties": false
    },
    "measurementSource": {
      "type": "object",
      "required": [
        "source_id",
        "source_kind",
        "source_timezone",
        "metrics",
        "data_as_of",
        "finality",
        "preliminary",
        "row_limit_hit",
        "pagination_complete",
        "sampling_rate",
        "thresholding_applied",
        "data_quality",
        "attribution_model"
      ],
      "properties": {
        "source_id": {"type": "string", "minLength": 1},
        "source_kind": {"type": "string", "minLength": 1},
        "source_timezone": {"type": ["string", "null"]},
        "metrics": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "data_as_of": {"type": ["string", "null"]},
        "finality": {"enum": ["final", "preliminary", "unknown"]},
        "preliminary": {"type": "boolean"},
        "row_limit_hit": {"type": ["boolean", "null"]},
        "pagination_complete": {"type": ["boolean", "null"]},
        "sampling_rate": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "thresholding_applied": {"type": ["boolean", "null"]},
        "data_quality": {"$ref": "#/$defs/sourceDataQuality"},
        "attribution_model": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    },
    "measurementContract": {
      "type": "object",
      "required": [
        "analysis_timezone",
        "temporal_grain",
        "source_timezones",
        "daily_cross_source_join_allowed",
        "window_aggregation_allowed",
        "sources",
        "issues",
        "complete",
        "status",
        "metadata_file_sha256"
      ],
      "properties": {
        "analysis_timezone": {"type": ["string", "null"]},
        "temporal_grain": {"const": "date"},
        "source_timezones": {
          "type": "object",
          "additionalProperties": {"type": ["string", "null"]}
        },
        "daily_cross_source_join_allowed": {"type": "boolean"},
        "window_aggregation_allowed": {"const": true},
        "sources": {
          "type": "object",
          "additionalProperties": {"$ref": "#/$defs/measurementSource"}
        },
        "issues": {"type": "array", "items": {"$ref": "#/$defs/issue"}},
        "complete": {"type": "boolean"},
        "status": {"enum": ["complete", "inconclusive"]},
        "metadata_file_sha256": {
          "oneOf": [
            {"$ref": "#/$defs/sha256"},
            {"type": "null"}
          ]
        }
      },
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "complete"}}, "required": ["status"]},
          "then": {"properties": {"complete": {"const": true}, "issues": {"maxItems": 0}}}
        },
        {
          "if": {"properties": {"status": {"const": "inconclusive"}}, "required": ["status"]},
          "then": {"properties": {"complete": {"const": false}, "issues": {"minItems": 1}}}
        }
      ],
      "additionalProperties": false
    },
    "arm": {
      "type": "object",
      "required": [
        "units",
        "baseline_mean",
        "current_mean",
        "absolute_change",
        "relative_change"
      ],
      "properties": {
        "units": {"type": "integer", "minimum": 0},
        "baseline_mean": {"$ref": "#/$defs/nullableNumber"},
        "current_mean": {"$ref": "#/$defs/nullableNumber"},
        "absolute_change": {"$ref": "#/$defs/nullableNumber"},
        "relative_change": {"$ref": "#/$defs/nullableNumber"}
      },
      "additionalProperties": false
    },
    "confidenceInterval": {
      "type": "object",
      "required": ["level", "method", "lower", "upper", "half_width"],
      "properties": {
        "level": {"type": "number", "exclusiveMinimum": 0, "exclusiveMaximum": 1},
        "method": {"const": "normal_approximation"},
        "lower": {"$ref": "#/$defs/nullableNumber"},
        "upper": {"$ref": "#/$defs/nullableNumber"},
        "half_width": {"type": ["number", "null"], "minimum": 0}
      },
      "additionalProperties": false
    },
    "detectability": {
      "type": "object",
      "required": [
        "preregistered_mde",
        "mde_scale",
        "mde_in_metric_units",
        "precision_sufficient_for_mde",
        "power",
        "note"
      ],
      "properties": {
        "preregistered_mde": {"type": "number", "exclusiveMinimum": 0},
        "mde_scale": {"enum": ["absolute", "relative_to_control_baseline"]},
        "mde_in_metric_units": {"type": ["number", "null"], "exclusiveMinimum": 0},
        "precision_sufficient_for_mde": {"type": "boolean"},
        "power": {"type": "null"},
        "note": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "metricEstimate": {
      "type": "object",
      "required": [
        "metric",
        "unit_of_analysis",
        "arms",
        "difference_in_differences",
        "relative_difference_in_differences",
        "standard_error",
        "confidence_interval",
        "inference_units",
        "detectability"
      ],
      "properties": {
        "metric": {"type": "string", "minLength": 1},
        "unit_of_analysis": {"enum": ["page", "matched_pair"]},
        "arms": {
          "type": "object",
          "required": ["treatment", "control"],
          "properties": {
            "treatment": {"$ref": "#/$defs/arm"},
            "control": {"$ref": "#/$defs/arm"}
          },
          "additionalProperties": false
        },
        "difference_in_differences": {"$ref": "#/$defs/nullableNumber"},
        "relative_difference_in_differences": {"$ref": "#/$defs/nullableNumber"},
        "standard_error": {"type": ["number", "null"], "minimum": 0},
        "confidence_interval": {"$ref": "#/$defs/confidenceInterval"},
        "inference_units": {"type": "integer", "minimum": 0},
        "detectability": {"$ref": "#/$defs/detectability"}
      },
      "additionalProperties": false
    },
    "guardrailResult": {
      "type": "object",
      "required": [
        "metric",
        "direction",
        "threshold",
        "difference_in_differences",
        "passed"
      ],
      "properties": {
        "metric": {"type": "string", "minLength": 1},
        "direction": {"enum": ["non_decrease", "non_increase"]},
        "threshold": {"type": "number", "minimum": 0},
        "difference_in_differences": {"$ref": "#/$defs/nullableNumber"},
        "passed": {"type": ["boolean", "null"]}
      },
      "additionalProperties": false
    },
    "guardrails": {
      "type": "object",
      "required": ["passed", "results"],
      "properties": {
        "passed": {"type": "boolean"},
        "results": {
          "type": "array",
          "items": {"$ref": "#/$defs/guardrailResult"}
        }
      },
      "allOf": [
        {
          "if": {"properties": {"passed": {"const": true}}, "required": ["passed"]},
          "then": {"properties": {"results": {"items": {"properties": {"passed": {"const": true}}}}}}
        },
        {
          "if": {"properties": {"passed": {"const": false}}, "required": ["passed"]},
          "then": {"properties": {"results": {"minItems": 1, "contains": {"properties": {"passed": {"enum": [false, null]}}, "required": ["passed"]}}}}
        }
      ],
      "additionalProperties": false
    },
    "eligibilityDetails": {
      "type": "object",
      "required": [
        "eligible_incremental",
        "reasons",
        "business_verdict",
        "primary_metric_direction",
        "point_estimate_supports_direction",
        "confidence_interval_supports_direction",
        "incremental_positive_allowed",
        "no_detectable_change_allowed"
      ],
      "properties": {
        "eligible_incremental": {"type": "boolean"},
        "reasons": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "business_verdict": {"type": "null"},
        "primary_metric_direction": {"enum": ["increase", "decrease"]},
        "point_estimate_supports_direction": {"type": "boolean"},
        "confidence_interval_supports_direction": {"type": "boolean"},
        "incremental_positive_allowed": {"type": "boolean"},
        "no_detectable_change_allowed": {"const": false}
      },
      "allOf": [
        {
          "if": {"properties": {"incremental_positive_allowed": {"const": true}}, "required": ["incremental_positive_allowed"]},
          "then": {"properties": {"eligible_incremental": {"const": true}, "point_estimate_supports_direction": {"const": true}, "confidence_interval_supports_direction": {"const": true}}}
        },
        {
          "if": {
            "properties": {
              "eligible_incremental": {"const": true},
              "point_estimate_supports_direction": {"const": true},
              "confidence_interval_supports_direction": {"const": true}
            },
            "required": [
              "eligible_incremental",
              "point_estimate_supports_direction",
              "confidence_interval_supports_direction"
            ]
          },
          "then": {"properties": {"incremental_positive_allowed": {"const": true}}}
        }
      ],
      "additionalProperties": false
    },
    "methodology": {
      "type": "object",
      "required": [
        "estimand",
        "causal_claim_automated",
        "power_calculated",
        "causality_boundary",
        "paid_search_boundary",
        "power_boundary"
      ],
      "properties": {
        "estimand": {"const": "page-level difference-in-differences"},
        "causal_claim_automated": {"const": false},
        "power_calculated": {"const": false},
        "causality_boundary": {"type": "string", "minLength": 1},
        "paid_search_boundary": {"type": "string", "minLength": 1},
        "power_boundary": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    }
  }
}
